---
layout: default
---

<div class="flex flex-col xl:flex-row">
  <div class="flex-auto">
    {% include "blocks/header.njk" %}
    <main class="text-gray-700 bg-gray-200 dark:text-gray-300 dark:bg-gray-800">
      <article id="page">
        <div class="lg:grid grid-cols-24 gap-4 px-4 sm:px-8 md:px-16 lg:px-12">
          {% set title = page.title %}
          {% set summary = page.summary %}
          {% set description = page.description %}
          {% include "utils/header.njk" %}
        </div>
        {{ content | safe }}
      </article>
    </main>
    <footer>
      {% include "blocks/footer.njk" %}
    </footer>
  </div>
  <aside class="flex-none">
    {% include "blocks/aside.njk" %}
  </aside>
</div>
